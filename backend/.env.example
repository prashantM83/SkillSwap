# Server Configuration
PORT=5000

# Database Configuration
# Use MONGO_URI so it matches process.env.MONGO_URI in your code
# Add a database name at the end (e.g., skillSwapDB)
MONGO_URI=mongodb://127.0.0.1:27017/skillSwapDB

# Environment
NODE_ENV=development

# JWT Configuration
# Make sure to replace these with strong, random secrets in production
JWT_SECRET=demo_jwt_secret_key_skillswap_2024_abcdefghijklmnop
JWT_REFRESH_SECRET=demo_refresh_secret_key_skillswap_2024_qrstuvwxyz
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Gmail SMTP)
# For Gmail, use an App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=skillswap.demo@gmail.com
SMTP_PASS=demo_app_password_1234
SMTP_FROM=skillswap.demo@gmail.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Optional: CORS Configuration (if needed)
# Uncomment and set to your frontend URL
# CORS_ORIGIN=http://localhost:5173

# Optional: Rate Limiting (if needed)
# Uncomment and adjust values as required
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
